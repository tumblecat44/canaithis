# CanAIThis — 채점용 환경 변수 템플릿
# 실제 비밀값은 제출 ZIP에 포함하지 않습니다. 채점 시 아래를 채운 뒤 .env.local 로 복사하세요.
# 기획서 8장: OAuth·DB 비밀번호는 채점용 임시 키로 교체 후 제출/채점합니다.

# Supabase (Transaction pooler 6543 + session 5432)
# 프로젝트 ref·비밀번호는 Supabase 대시보드 → Settings → Database
DATABASE_URL="postgresql://postgres%2E[PROJECT_REF]:[DB_PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres%2E[PROJECT_REF]:[DB_PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_AUTH_SECRET_FOR_GRADING"

# 로컬 채점
AUTH_URL="http://localhost:3000"

# GitHub OAuth App (채점 전용 앱 권장)
GITHUB_ID="REPLACE_GITHUB_OAUTH_CLIENT_ID"
GITHUB_SECRET="REPLACE_GITHUB_OAUTH_CLIENT_SECRET"

# Google Cloud OAuth Web client (채점 전용 권장)
# Redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_ID="REPLACE_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_SECRET="REPLACE_GOOGLE_OAUTH_CLIENT_SECRET"